{
  "manifest_version": 3,
  "name": "Verificador de Nomes",
  "version": "1.3.0",
  "description": "Abre as pesquisas do Verificador de Nomes, mostra checks no painel lateral da extensão e automatiza a navegação do INPI.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://busca.inpi.gov.br/*",
    "https://busca.inpi.gov.br/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.github.io/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "page_bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Verificador de Nomes",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
